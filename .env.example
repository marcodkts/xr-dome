# XR Dome runtime config

# Path preferred by the VITURE loader in this repo.
VITURE_SDK_ROOT=./viture_sdk

# Optional direct override.
# VITURE_SDK_LIB=./viture_sdk/libs/libviture_one_sdk.so

# Enable IMU debug logs from the SDK sample-style stream.
VITURE_LOG_IMU=1

# Optional per-frame tracking trace.
# VITURE_TRACE_TRACKING=1

# Raw IMU is the default. Use "auto" if you want quaternion fallback.
# VITURE_ORIENTATION_FORMAT=raw12

# Optional calibration offsets applied on top of the raw IMU reading.
# These are useful for small hardware-specific corrections.
# VITURE_YAW_OFFSET_DEGREES=0
# VITURE_PITCH_OFFSET_DEGREES=0
# VITURE_ROLL_OFFSET_DEGREES=0

# Start with the first valid head pose centered in the scene.
# Disable this if you want the raw IMU zero to stay untouched.
VITURE_AUTO_CENTER_ON_START=1

# XR layout defaults.
XR_DOME_OBSERVER_DISTANCE_M=2.5
XR_DOME_DOME_YAW_DEGREES=140
XR_DOME_DOME_MIN_PITCH_DEGREES=-30
XR_DOME_DOME_MAX_PITCH_DEGREES=30
XR_DOME_WORKSPACE_YAW_DEGREES=140
XR_DOME_WORKSPACE_PITCH_DEGREES=60

# Optional logging configuration.
# RUST_LOG=xr_dome=info
